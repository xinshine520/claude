# pg-mcp Environment Variables
# Copy to .env and fill in your values.
# See README.md for quick start and config reference.

# ---------------------------------------------------------------------------
# Databases (required)
# ---------------------------------------------------------------------------
# Comma-separated database aliases (e.g. mydb,analytics)
PG_MCP_DATABASES=mydb

# Per-database configuration (replace MYDB with your alias in uppercase)
# Option 1: Full connection URL (recommended)
PG_MCP_MYDB_URL=postgresql://user:password@localhost:5432/mydb

# Option 2: Individual components
# PG_MCP_MYDB_HOST=localhost
# PG_MCP_MYDB_PORT=5432
# PG_MCP_MYDB_DATABASE=mydb
# PG_MCP_MYDB_USER=user
# PG_MCP_MYDB_PASSWORD=secret
# PG_MCP_MYDB_SSLMODE=prefer

# ---------------------------------------------------------------------------
# LLM (required for SQL generation)
# ---------------------------------------------------------------------------
# DeepSeek / OpenAI compatible API
PG_MCP_LLM_API_KEY=sk-your-api-key
PG_MCP_LLM_BASE_URL=https://api.deepseek.com
PG_MCP_LLM_MODEL=deepseek-chat
PG_MCP_LLM_MAX_TOKENS=4096
PG_MCP_LLM_TEMPERATURE=0.0

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PG_MCP_STATEMENT_TIMEOUT=30s
PG_MCP_LOCK_TIMEOUT=5s
PG_MCP_DEFAULT_MAX_ROWS=100
PG_MCP_MAX_FIELD_SIZE=10240
PG_MCP_MAX_PAYLOAD_SIZE=5242880
PG_MCP_POOL_SIZE_PER_DB=5
PG_MCP_MAX_CONCURRENT_QUERIES=20
PG_MCP_MAX_SQL_LENGTH=10000
PG_MCP_LOG_LEVEL=INFO

# Schema cache
PG_MCP_COLLECT_VIEW_DEFINITIONS=true
PG_MCP_SCHEMA_CACHE_TTL=3600
PG_MCP_MAX_TABLES_PER_DB=500

# Verification (off | metadata | sample)
PG_MCP_VERIFY_MODE=off
PG_MCP_VERIFY_SAMPLE_ROWS=5

# Optional: Bearer token for SSE transport
# PG_MCP_ACCESS_TOKEN=your-secret-token

# ---------------------------------------------------------------------------
# Phase 9: Per-database security (optional)
# Replace MYDB with your alias in uppercase
# ---------------------------------------------------------------------------
# PG_MCP_MYDB_ALLOWED_SCHEMAS=analytics,reporting
# PG_MCP_MYDB_ALLOWED_TABLES=users,orders
# PG_MCP_MYDB_DENIED_TABLES=secrets,audit_log
# PG_MCP_MYDB_ALLOW_EXPLAIN=false
# PG_MCP_MYDB_MAX_ROWS_OVERRIDE=500

# ---------------------------------------------------------------------------
# Phase 10: Resilience & observability
# ---------------------------------------------------------------------------
# PG_MCP_RATE_LIMIT_RPM=60
# PG_MCP_LLM_MAX_RETRIES=3
# PG_MCP_LLM_RETRY_BASE_DELAY=1.0
# PG_MCP_METRICS_ENABLED=true

# ---------------------------------------------------------------------------
# E2E tests (optional)
# ---------------------------------------------------------------------------
# PG_MCP_E2E_DSN=postgresql://postgres:postgres@localhost:5433/pg_mcp_test
